# ── Required for production ───────────────────────────────────────────────────

# Absolute path to the SQLite database file.
# Uploads are stored in an "uploads/" folder next to the database.
DATABASE_PATH=./data/munchbase.db

# Your public-facing URL in production, including https://.
# Example: APP_ORIGIN=https://munchbase.example.com
APP_ORIGIN=http://localhost:3000

# ── Optional ──────────────────────────────────────────────────────────────────

# Maximum photo upload size in MB (default: 10).
PHOTO_MAX_SIZE_MB=100

# Comma-separated hostnames/IPs allowed to access the dev server cross-origin (dev only).
# ALLOWED_DEV_ORIGINS=192.168.1.100,munchbase.local

# OpenStreetMap Nominatim user agent (required by OSM ToS — set to your app name/URL).
OSM_USER_AGENT=munchbase/0.1 (self-hosted restaurant tracker)

# Map tile URL template. Default uses OSM; swap for a self-hosted or commercial tile server.
NEXT_PUBLIC_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
