{
  "name": "munchbase",
  "version": "1.0.0",
  "description": "Self-hosted restaurant tracker",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "db:generate": "mkdir -p data && drizzle-kit generate",
    "db:migrate": "mkdir -p data && drizzle-kit migrate",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "restaurants",
    "self-hosted"
  ],
  "author": "",
