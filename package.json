    "@types/leaflet": "^1.9.21",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "idb": "^8.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "sharp": "^0.35.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
