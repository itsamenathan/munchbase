{
  "name": "munchbase",
  "version": "1.0.0",
  "description": "Self-hosted restaurant tracker",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3001",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "db:generate": "node -e \"require('node:fs').mkdirSync('data',{recursive:true})\" && drizzle-kit generate",
    "db:migrate": "tsx scripts/database-cli.ts migrate",
    "db:check": "drizzle-kit check",
    "db:integrity": "tsx scripts/database-cli.ts integrity",
    "db:seed:test": "node scripts/seed-test-data.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:migrations": "vitest run src/lib/database/database.test.ts",
    "test:watch": "vitest"
  },
  "keywords": [
    "restaurants",
    "self-hosted"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@serwist/next": "^9.5.11",
    "@serwist/sw": "^9.5.11",
    "@types/leaflet": "^1.9.21",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "idb": "^8.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.18.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "sharp": "^0.35.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "agent-browser": "^0.31.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "agent-browser@0.31.1": true,
    "sharp@0.34.5": true,
    "sharp@0.35.2": true,
    "unrs-resolver@1.12.2": true
  }
}
